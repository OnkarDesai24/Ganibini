{
  "entities": {
    "Song": {
      "title": "Song",
      "description": "A song with lyrics and metadata",
      "type": "object",
      "properties": {
        "title": {
          "type": "object",
          "properties": {
            "en": { "type": "string" },
            "mr": { "type": "string" }
          },
          "required": ["en", "mr"]
        },
        "slug": { "type": "string", "description": "SEO-friendly URL slug" },
        "artist_names": { "type": "array", "items": { "type": "string" }, "description": "List of artists" },
        "language": { "type": "string", "description": "Song language" },
        "lyrics": {
          "type": "object",
          "properties": {
            "mr": { "type": "string" }
          },
          "required": ["mr"]
        },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Approval status" },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "movie": { "type": "string", "description": "Movie or Album name" },
        "youtube_link": { "type": "string", "description": "YouTube video URL" },
        "is_trending": { "type": "boolean" },
        "genre": { "type": "string" },
        "year": { "type": "number" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "meaning": { "type": "string" },
        "story": { "type": "string" },
        "submitted_by": { "type": "string" },
        "submitted_by_name": { "type": "string" },
        "submitted_by_email": { "type": "string" },
        "lyricist": { "type": "string" },
        "composer": { "type": "string" },
        "song_name": { "type": "string" },
        "singer": { "type": "string" }
      },
      "required": ["title", "slug", "artist_names", "language", "lyrics", "status", "created_at"]
    },
    "User": {
      "title": "User",
      "description": "App user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "contributor", "user"] }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/songs/{songId}": {
      "schema": "Song",
      "description": "Collection of songs"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    }
  }
}
